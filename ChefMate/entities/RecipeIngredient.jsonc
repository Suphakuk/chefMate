      "type": "string"
    },
    "ingredient_id": {
      "type": "string"
    },
    "quantity": {
      "type": "number",
      "default": 1
    },
    "unit": {
      "type": "string",
      "default": "g"
    },
    "is_optional": {
      "type": "boolean",
      "default": false
    }
  },
